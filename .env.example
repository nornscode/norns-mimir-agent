# Core Norns + LLM
NORNS_URL=http://localhost:4001
NORNS_API_KEY=
ANTHROPIC_API_KEY=

# Database (memory storage)
DATABASE_URL=postgresql://mimir_agent:mimir_agent@localhost:5433/mimir_agent

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
