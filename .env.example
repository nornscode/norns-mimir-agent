# Core Norns + LLM
# Run `nornsctl dev status` to see the URL and API key — defaults to localhost:4000
NORNS_URL=http://localhost:4000
NORNS_API_KEY=
ANTHROPIC_API_KEY=

# Database (memory storage)
DATABASE_URL=postgresql://mimir_agent:mimir_agent@localhost:5433/mimir_agent

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# GitHub (optional)
GITHUB_TOKEN=
# comma-separated owner/repo list
GITHUB_REPOS=
