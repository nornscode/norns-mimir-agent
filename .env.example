# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord (optional)
DISCORD_BOT_TOKEN=

# GitHub (optional)
GITHUB_TOKEN=
# comma-separated owner/repo list
GITHUB_REPOS=

# Google Docs (optional)
GOOGLE_CREDENTIALS_PATH=
# comma-separated doc IDs
GOOGLE_DOC_IDS=

# Figma (optional)
FIGMA_ACCESS_TOKEN=
# comma-separated file keys
FIGMA_FILE_KEYS=
